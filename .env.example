# Copier ce fichier en .env pour le développement local
# Sur Railway : définir ces variables dans Settings > Variables

# Clé secrète pour les tokens JWT (changez cette valeur !)
JWT_SECRET=changez_cette_valeur_en_production_2025

# Dossier de stockage des données persistantes
# Sur Railway : mettre /data (après avoir monté un Volume sur /data)
# En local   : laisser vide (utilise le dossier du projet)
DATA_DIR=
